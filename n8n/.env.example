# n8n — variaveis de ambiente
# Copie para .env (nao vai pro git) e preencha antes do 'docker compose up -d'

# Basic auth para o painel do n8n (troque!)
N8N_USER=admin
N8N_PASSWORD=TROCAR_ESTA_SENHA_AGORA

# Chave de criptografia das credenciais salvas dentro do n8n.
# GERE UMA VEZ e nunca perca (se perder, todas as credenciais viram inutilizaveis).
# Comando: openssl rand -hex 32
N8N_ENCRYPTION_KEY=
