{
  "id": "painel_tv",
  "nome": "Painel de TV",
  "categoria": "sala",
  "descricao": "Painel suspenso para TV com nichos abertos, gavetas e/ou portas laterais",
  "icone": "painel_tv",
  "thumbnail": "painel_tv.png",

  "parametros": {
    "largura":      { "label": "Largura (mm)",     "default": 2400, "min": 1200, "max": 4000, "step": 100 },
    "altura":       { "label": "Altura (mm)",      "default": 500,  "min": 300,  "max": 900,  "step": 50  },
    "profundidade": { "label": "Profundidade (mm)", "default": 350,  "min": 250,  "max": 500,  "step": 10  },
    "espessura":    { "label": "Espessura MDF",    "default": 18,   "min": 15,   "max": 25,   "step": 1   },
    "material":     { "label": "Material",         "default": "MDF18_BrancoTX" },
    "com_fundo":    { "label": "Com fundo",        "default": true  },
    "n_gavetas":    { "label": "Gavetas centrais", "default": 2,    "min": 0,    "max": 4,    "step": 1   },
    "largura_nicho":{ "label": "Largura nichos laterais (mm)", "default": 400, "min": 200, "max": 600, "step": 50 }
  },

  "pecas": [
    {
      "nome": "Lateral Esq",
      "role": "lateral",
      "largura":   "{altura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": 0, "y": 0, "z": 0 },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": false }
    },
    {
      "nome": "Lateral Dir",
      "role": "lateral",
      "largura":   "{altura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{largura} - {espessura}", "y": 0, "z": 0 },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": false }
    },
    {
      "nome": "Divisória Esq",
      "role": "divider",
      "largura":   "{altura} - {espessura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{largura_nicho}",
        "y": 0,
        "z": "{espessura}"
      },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false }
    },
    {
      "nome": "Divisória Dir",
      "role": "divider",
      "largura":   "{altura} - {espessura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{largura} - {largura_nicho} - {espessura}",
        "y": 0,
        "z": "{espessura}"
      },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false }
    },
    {
      "nome": "Base",
      "role": "base",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": 0 },
      "bordas": { "frente": true, "topo": false, "base": true, "tras": false }
    },
    {
      "nome": "Topo",
      "role": "top",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura} - {espessura}" },
      "bordas": { "frente": true, "topo": true, "base": false, "tras": false }
    },
    {
      "nome": "Traseira",
      "role": "back_panel",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{altura} - 2 * {espessura}",
      "espessura": 3,
      "posicao": { "x": "{espessura}", "y": "{profundidade} - 13", "z": "{espessura}" },
      "bordas": { "frente": false, "topo": false, "base": false, "tras": false },
      "condicao": "{com_fundo} == true"
    },
    {
      "nome": "Frente Gaveta 1",
      "role": "drawer_front",
      "largura":   "round(({altura} - 2 * {espessura}) / {n_gavetas}) - 2",
      "altura":    "{largura} - 2 * {largura_nicho} - 3 * {espessura} - 2",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{largura_nicho} + {espessura} + 1",
        "y": 0,
        "z": "{espessura} + 1"
      },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": true },
      "condicao": "{n_gavetas} >= 1"
    },
    {
      "nome": "Frente Gaveta 2",
      "role": "drawer_front",
      "largura":   "round(({altura} - 2 * {espessura}) / {n_gavetas}) - 2",
      "altura":    "{largura} - 2 * {largura_nicho} - 3 * {espessura} - 2",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{largura_nicho} + {espessura} + 1",
        "y": 0,
        "z": "{espessura} + round(({altura} - 2 * {espessura}) / {n_gavetas}) + 1"
      },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": true },
      "condicao": "{n_gavetas} >= 2"
    }
  ],

  "ferragens_auto": [
    { "tipo": "corredica", "aplica_em": "drawer_front", "modelo": "{corredica}" },
    { "tipo": "puxador",   "aplica_em": "drawer_front", "espacamento": 128 },
    { "tipo": "minifix",   "aplica_em": ["lateral", "divider", "base", "top"] }
  ],

  "agregados_sugeridos": ["led", "espelho"]
}
