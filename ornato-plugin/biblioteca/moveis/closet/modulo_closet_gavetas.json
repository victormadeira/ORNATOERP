{
  "id": "modulo_closet_gavetas",
  "nome": "Modulo Closet Gaveteiro",
  "descricao": "Modulo de closet com 4-6 gavetas na parte inferior e prateleiras acima.",
  "categoria": "closet",
  "tags": ["closet", "gaveteiro", "gavetas", "prateleiras", "modulo"],
  "icone": "closet",

  "parametros": {
    "largura":       { "default": 700,  "min": 600, "max": 800,  "step": 50, "unidade": "mm" },
    "altura":        { "default": 2200, "min": 2200, "max": 2200, "step": 50, "unidade": "mm" },
    "profundidade":  { "default": 500,  "min": 500, "max": 500,  "step": 10, "unidade": "mm" },
    "espessura":     { "default": 18,   "min": 15,  "max": 25,   "step": 0.5, "unidade": "mm" },
    "n_gavetas":     { "default": 5,    "min": 4,   "max": 6,    "step": 1 },
    "n_prateleiras": { "default": 2,    "min": 1,   "max": 3,    "step": 1 },
    "altura_gaveta": { "default": 180,  "min": 140, "max": 220,  "step": 10, "unidade": "mm" },
    "tipo_juncao":   { "default": "minifix", "opcoes": ["minifix", "cavilha", "confirmat"] },
    "com_fundo":     { "default": true },
    "com_rodape":    { "default": true, "altura_rodape": 100 },
    "puxador":       { "default": "modelo_128mm" }
  },

  "pecas": [
    {
      "nome": "Lateral Esquerda",
      "role": "lateral_esq",
      "largura": "{altura} - {altura_rodape}",
      "altura": "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": 0, "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Lateral Direita",
      "role": "lateral_dir",
      "largura": "{altura} - {altura_rodape}",
      "altura": "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{largura} - {espessura}", "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Base",
      "role": "base",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Topo",
      "role": "topo",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura} - {espessura}" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Traseira",
      "role": "traseira",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{altura} - {altura_rodape} - 2 * {espessura}",
      "espessura": 3,
      "condicao": "{com_fundo}",
      "posicao": { "x": "{espessura}", "y": "{profundidade} - 13", "z": "{altura_rodape} + {espessura}" },
      "bordas": { "frontal": false, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Frente Gaveta 1",
      "role": "frente_gaveta",
      "largura": "{altura_gaveta} - 2",
      "altura": "{largura} - 2 * {espessura} - 4",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura} + 2", "y": 0, "z": "{altura_rodape} + {espessura} + 1" },
      "bordas": { "frontal": true, "traseira": true, "dir": true, "esq": true }
    },
    {
      "nome": "Frente Gaveta 2",
      "role": "frente_gaveta",
      "largura": "{altura_gaveta} - 2",
      "altura": "{largura} - 2 * {espessura} - 4",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura} + 2", "y": 0, "z": "{altura_rodape} + {espessura} + {altura_gaveta} + 1" },
      "bordas": { "frontal": true, "traseira": true, "dir": true, "esq": true }
    },
    {
      "nome": "Frente Gaveta 3",
      "role": "frente_gaveta",
      "largura": "{altura_gaveta} - 2",
      "altura": "{largura} - 2 * {espessura} - 4",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura} + 2", "y": 0, "z": "{altura_rodape} + {espessura} + 2 * {altura_gaveta} + 1" },
      "bordas": { "frontal": true, "traseira": true, "dir": true, "esq": true }
    },
    {
      "nome": "Frente Gaveta 4",
      "role": "frente_gaveta",
      "largura": "{altura_gaveta} - 2",
      "altura": "{largura} - 2 * {espessura} - 4",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura} + 2", "y": 0, "z": "{altura_rodape} + {espessura} + 3 * {altura_gaveta} + 1" },
      "bordas": { "frontal": true, "traseira": true, "dir": true, "esq": true }
    },
    {
      "nome": "Frente Gaveta 5",
      "role": "frente_gaveta",
      "largura": "{altura_gaveta} - 2",
      "altura": "{largura} - 2 * {espessura} - 4",
      "espessura": "{espessura}",
      "condicao": "{n_gavetas} >= 5",
      "posicao": { "x": "{espessura} + 2", "y": 0, "z": "{altura_rodape} + {espessura} + 4 * {altura_gaveta} + 1" },
      "bordas": { "frontal": true, "traseira": true, "dir": true, "esq": true }
    },
    {
      "nome": "Frente Gaveta 6",
      "role": "frente_gaveta",
      "largura": "{altura_gaveta} - 2",
      "altura": "{largura} - 2 * {espessura} - 4",
      "espessura": "{espessura}",
      "condicao": "{n_gavetas} >= 6",
      "posicao": { "x": "{espessura} + 2", "y": 0, "z": "{altura_rodape} + {espessura} + 5 * {altura_gaveta} + 1" },
      "bordas": { "frontal": true, "traseira": true, "dir": true, "esq": true }
    },
    {
      "nome": "Prateleira 1",
      "role": "prateleira",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{profundidade} - 20",
      "espessura": "{espessura}",
      "condicao": "{n_prateleiras} >= 1",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura_rodape} + {espessura} + {n_gavetas} * {altura_gaveta} + ({altura} - {altura_rodape} - {espessura} - {n_gavetas} * {altura_gaveta}) / ({n_prateleiras} + 1)" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Prateleira 2",
      "role": "prateleira",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{profundidade} - 20",
      "espessura": "{espessura}",
      "condicao": "{n_prateleiras} >= 2",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura_rodape} + {espessura} + {n_gavetas} * {altura_gaveta} + 2 * ({altura} - {altura_rodape} - {espessura} - {n_gavetas} * {altura_gaveta}) / ({n_prateleiras} + 1)" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Rodape",
      "role": "rodape",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{altura_rodape}",
      "espessura": "{espessura}",
      "condicao": "{com_rodape}",
      "posicao": { "x": "{espessura}", "y": 50, "z": 0 },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    }
  ],

  "ferragens_auto": [
    { "regra": "minifix", "juncao": "lateral_esq × base", "condicao": "{tipo_juncao} == 'minifix'" },
    { "regra": "minifix", "juncao": "lateral_dir × base", "condicao": "{tipo_juncao} == 'minifix'" },
    { "regra": "minifix", "juncao": "lateral_esq × topo", "condicao": "{tipo_juncao} == 'minifix'" },
    { "regra": "minifix", "juncao": "lateral_dir × topo", "condicao": "{tipo_juncao} == 'minifix'" },
    { "regra": "cavilha", "juncao": "lateral_esq × base", "condicao": "{tipo_juncao} == 'cavilha'" },
    { "regra": "cavilha", "juncao": "lateral_dir × base", "condicao": "{tipo_juncao} == 'cavilha'" },
    { "regra": "corredica", "peca": "lateral_esq", "condicao": "true" },
    { "regra": "corredica", "peca": "lateral_dir", "condicao": "true" },
    { "regra": "rebaixo_fundo", "pecas": ["lateral_esq", "lateral_dir", "base", "topo"], "condicao": "{com_fundo}" },
    { "regra": "puxador", "peca": "frente_gaveta", "condicao": "true" },
    { "regra": "system32", "pecas": ["lateral_esq", "lateral_dir"], "condicao": "{n_prateleiras} > 0" }
  ],

  "notas": "Closet aberto sem portas. Gavetas na parte inferior, prateleiras regulaveis na parte superior."
}
