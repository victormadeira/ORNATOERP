{
  "id": "guarda_roupa_4p",
  "nome": "Guarda-Roupa 4 Portas",
  "categoria": "dormitorio",
  "descricao": "Guarda-roupa de 4 portas de abrir com divisão central, cabideiro e prateleiras",
  "icone": "guarda_roupa",
  "thumbnail": "guarda_roupa_4p.png",

  "parametros": {
    "largura":      { "label": "Largura (mm)",     "default": 1600, "min": 1200, "max": 2800, "step": 100 },
    "altura":       { "label": "Altura (mm)",      "default": 2200, "min": 1800, "max": 2800, "step": 50  },
    "profundidade": { "label": "Profundidade (mm)", "default": 600,  "min": 500,  "max": 700,  "step": 10  },
    "espessura":    { "label": "Espessura MDF",    "default": 18,   "min": 15,   "max": 25,   "step": 1   },
    "altura_rodape":{ "label": "Rodapé (mm)",      "default": 100,  "min": 0,    "max": 150,  "step": 10  },
    "material":     { "label": "Material",         "default": "MDF18_BrancoTX" },
    "com_tampo":    { "label": "Com tampo",        "default": true  },
    "com_fundo":    { "label": "Com fundo",        "default": true  },
    "n_prateleiras":{ "label": "Prateleiras por vão", "default": 2, "min": 0, "max": 6, "step": 1 },
    "altura_cabideiro": { "label": "Altura seção cabideiro (mm)", "default": 1000, "min": 600, "max": 1400, "step": 50 }
  },

  "pecas": [
    {
      "nome": "Lateral Esq",
      "role": "lateral",
      "largura":   "{altura} - {altura_rodape}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": 0, "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frente": true, "topo": true, "base": false, "tras": false }
    },
    {
      "nome": "Lateral Dir",
      "role": "lateral",
      "largura":   "{altura} - {altura_rodape}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{largura} - {espessura}", "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frente": true, "topo": true, "base": false, "tras": false }
    },
    {
      "nome": "Divisória Central",
      "role": "divider",
      "largura":   "{altura} - {altura_rodape} - {espessura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{largura} / 2 - {espessura} / 2",
        "y": 0,
        "z": "{altura_rodape} + {espessura}"
      },
      "bordas": { "frente": true, "topo": true, "base": false, "tras": false }
    },
    {
      "nome": "Base",
      "role": "base",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false }
    },
    {
      "nome": "Tampo",
      "role": "top",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura} - {espessura}" },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{com_tampo} == true"
    },
    {
      "nome": "Traseira",
      "role": "back_panel",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{altura} - {altura_rodape} - 2 * {espessura}",
      "espessura": 3,
      "posicao": { "x": "{espessura}", "y": "{profundidade} - 13", "z": "{altura_rodape} + {espessura}" },
      "bordas": { "frente": false, "topo": false, "base": false, "tras": false },
      "condicao": "{com_fundo} == true"
    },
    {
      "nome": "Cabideiro Esq",
      "role": "rail",
      "largura":   "{largura} / 2 - 2 * {espessura} - {espessura} / 2",
      "altura":    "{profundidade} - 60",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura}",
        "y": 30,
        "z": "{altura} - {espessura} - {altura_cabideiro}"
      },
      "bordas": { "frente": false, "topo": false, "base": false, "tras": false }
    },
    {
      "nome": "Cabideiro Dir",
      "role": "rail",
      "largura":   "{largura} / 2 - 2 * {espessura} - {espessura} / 2",
      "altura":    "{profundidade} - 60",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{largura} / 2 + {espessura} / 2",
        "y": 30,
        "z": "{altura} - {espessura} - {altura_cabideiro}"
      },
      "bordas": { "frente": false, "topo": false, "base": false, "tras": false }
    },
    {
      "nome": "Prateleira Inf Esq",
      "role": "shelf",
      "largura":   "{largura} / 2 - 2 * {espessura} - {espessura} / 2",
      "altura":    "{profundidade} - 20",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura}",
        "y": 0,
        "z": "{altura_rodape} + {espessura} + round(({altura} - {altura_rodape} - {altura_cabideiro} - 2 * {espessura}) / ({n_prateleiras} + 1))"
      },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{n_prateleiras} >= 1"
    },
    {
      "nome": "Prateleira Inf Dir",
      "role": "shelf",
      "largura":   "{largura} / 2 - 2 * {espessura} - {espessura} / 2",
      "altura":    "{profundidade} - 20",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{largura} / 2 + {espessura} / 2",
        "y": 0,
        "z": "{altura_rodape} + {espessura} + round(({altura} - {altura_rodape} - {altura_cabideiro} - 2 * {espessura}) / ({n_prateleiras} + 1))"
      },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{n_prateleiras} >= 1"
    },
    {
      "nome": "Porta 1",
      "role": "door",
      "largura":   "{altura} - {altura_rodape} - 2 * {espessura} - 2",
      "altura":    "({largura} - 2 * {espessura}) / 4 - 2",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura} + 1",
        "y": 0,
        "z": "{altura_rodape} + {espessura} + 1"
      },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": true }
    },
    {
      "nome": "Porta 2",
      "role": "door",
      "largura":   "{altura} - {altura_rodape} - 2 * {espessura} - 2",
      "altura":    "({largura} - 2 * {espessura}) / 4 - 2",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{largura} / 4 + {espessura} / 2 + 1",
        "y": 0,
        "z": "{altura_rodape} + {espessura} + 1"
      },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": true }
    },
    {
      "nome": "Porta 3",
      "role": "door",
      "largura":   "{altura} - {altura_rodape} - 2 * {espessura} - 2",
      "altura":    "({largura} - 2 * {espessura}) / 4 - 2",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{largura} / 2 + {espessura} / 2 + 1",
        "y": 0,
        "z": "{altura_rodape} + {espessura} + 1"
      },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": true }
    },
    {
      "nome": "Porta 4",
      "role": "door",
      "largura":   "{altura} - {altura_rodape} - 2 * {espessura} - 2",
      "altura":    "({largura} - 2 * {espessura}) / 4 - 2",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{largura} * 3 / 4 + {espessura} / 4 + 1",
        "y": 0,
        "z": "{altura_rodape} + {espessura} + 1"
      },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": true }
    },
    {
      "nome": "Rodapé",
      "role": "kick",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{altura_rodape}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 50, "z": 0 },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{altura_rodape} > 0"
    }
  ],

  "ferragens_auto": [
    { "tipo": "dobradica",  "aplica_em": "door", "quantidade_por_folha": 4 },
    { "tipo": "puxador",   "aplica_em": "door",  "espacamento": 128 },
    { "tipo": "minifix",   "aplica_em": ["lateral", "divider", "base", "top"] },
    { "tipo": "cavilha",   "aplica_em": ["lateral", "divider", "shelf"] },
    { "tipo": "system32",  "aplica_em": ["lateral", "divider"], "condicao": "{n_prateleiras} > 0" }
  ],

  "agregados_sugeridos": ["cabideiro", "led"]
}
