{
  "id": "comoda_3g",
  "nome": "Cômoda 3 Gavetas",
  "categoria": "dormitorio",
  "descricao": "Cômoda de dormitório com 3 gavetas de alturas iguais, tampo e rodapé",
  "icone": "gaveteiro",
  "thumbnail": "comoda_3g.png",

  "parametros": {
    "largura":      { "label": "Largura (mm)",     "default": 900,  "min": 600,  "max": 1400, "step": 50 },
    "altura":       { "label": "Altura (mm)",      "default": 750,  "min": 600,  "max": 1000, "step": 10 },
    "profundidade": { "label": "Profundidade (mm)", "default": 480,  "min": 350,  "max": 600,  "step": 10 },
    "espessura":    { "label": "Espessura MDF",    "default": 18,   "min": 15,   "max": 25,   "step": 1  },
    "altura_rodape":{ "label": "Rodapé (mm)",      "default": 80,   "min": 0,    "max": 150,  "step": 10 },
    "material":     { "label": "Material Carcaça", "default": "MDF18_BrancoTX" },
    "com_tampo":    { "label": "Com tampo",        "default": true  },
    "com_fundo":    { "label": "Com fundo",        "default": true  }
  },

  "pecas": [
    {
      "nome": "Lateral Esq",
      "role": "lateral",
      "largura":   "{altura} - {altura_rodape}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": 0, "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frente": true, "topo": true, "base": false, "tras": false }
    },
    {
      "nome": "Lateral Dir",
      "role": "lateral",
      "largura":   "{altura} - {altura_rodape}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{largura} - {espessura}", "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frente": true, "topo": true, "base": false, "tras": false }
    },
    {
      "nome": "Base",
      "role": "base",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frente": false, "topo": false, "base": false, "tras": false }
    },
    {
      "nome": "Tampo",
      "role": "top",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura} - {espessura}" },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{com_tampo} == true"
    },
    {
      "nome": "Traseira",
      "role": "back_panel",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{altura} - {altura_rodape} - 2 * {espessura}",
      "espessura": 3,
      "posicao": { "x": "{espessura}", "y": "{profundidade} - 13", "z": "{altura_rodape} + {espessura}" },
      "bordas": { "frente": false, "topo": false, "base": false, "tras": false },
      "condicao": "{com_fundo} == true"
    },
    {
      "nome": "Frente Gaveta 1",
      "role": "drawer_front",
      "largura":   "round(({altura} - {altura_rodape} - {espessura}) / 3) - 2",
      "altura":    "{largura} - 2 * {espessura} - 2",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura} + 1",
        "y": 0,
        "z": "{altura_rodape} + {espessura} + 1"
      },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": true }
    },
    {
      "nome": "Frente Gaveta 2",
      "role": "drawer_front",
      "largura":   "round(({altura} - {altura_rodape} - {espessura}) / 3) - 2",
      "altura":    "{largura} - 2 * {espessura} - 2",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura} + 1",
        "y": 0,
        "z": "{altura_rodape} + {espessura} + round(({altura} - {altura_rodape} - {espessura}) / 3) + 1"
      },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": true }
    },
    {
      "nome": "Frente Gaveta 3",
      "role": "drawer_front",
      "largura":   "round(({altura} - {altura_rodape} - {espessura}) / 3) - 2",
      "altura":    "{largura} - 2 * {espessura} - 2",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura} + 1",
        "y": 0,
        "z": "{altura_rodape} + {espessura} + round(({altura} - {altura_rodape} - {espessura}) * 2 / 3) + 1"
      },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": true }
    },
    {
      "nome": "Rodapé",
      "role": "kick",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{altura_rodape}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 50, "z": 0 },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{altura_rodape} > 0"
    }
  ],

  "ferragens_auto": [
    { "tipo": "corredica", "aplica_em": "drawer_front", "modelo": "{corredica}" },
    { "tipo": "puxador",   "aplica_em": "drawer_front", "espacamento": 128 },
    { "tipo": "minifix",   "aplica_em": ["lateral", "base", "top"] },
    { "tipo": "cavilha",   "aplica_em": "lateral" }
  ],

  "agregados_sugeridos": []
}
