{
  "id": "balcao_atendimento",
  "nome": "Balcao Atendimento",
  "descricao": "Balcao comercial de atendimento. Tampo alto com prateleiras internas do lado do atendente.",
  "categoria": "comercial",
  "tags": [
    "balcao",
    "atendimento",
    "comercial",
    "loja"
  ],
  "icone": "balcao",
  "parametros": {
    "largura": {
      "default": 1800,
      "min": 1200,
      "max": 2400,
      "step": 100,
      "unidade": "mm",
      "label": "Largura",
      "type": "number",
      "unit": "mm"
    },
    "altura": {
      "default": 1100,
      "min": 1100,
      "max": 1100,
      "step": 50,
      "unidade": "mm",
      "label": "Altura",
      "type": "number",
      "unit": "mm"
    },
    "profundidade": {
      "default": 600,
      "min": 600,
      "max": 600,
      "step": 10,
      "unidade": "mm",
      "label": "Profundidade",
      "type": "number",
      "unit": "mm"
    },
    "espessura": {
      "default": 18,
      "min": 15,
      "max": 25,
      "step": 0.5,
      "unidade": "mm",
      "label": "Espessura MDF",
      "type": "number",
      "unit": "mm"
    },
    "n_prateleiras": {
      "default": 2,
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Prateleiras",
      "type": "number"
    },
    "tipo_juncao": {
      "default": "minifix",
      "opcoes": [
        "minifix",
        "cavilha",
        "confirmat"
      ],
      "label": "Juncao",
      "type": "select"
    },
    "com_fundo": {
      "default": true,
      "label": "Com fundo",
      "type": "boolean"
    },
    "com_rodape": {
      "default": true,
      "altura_rodape": 100,
      "label": "Com rodape",
      "type": "boolean"
    }
  },
  "pecas": [
    {
      "nome": "Lateral Esquerda",
      "role": "lateral_esq",
      "largura": "{altura} - {shop.altura_rodape}",
      "altura": "{profundidade}",
      "espessura": "{shop.espessura}",
      "posicao": {
        "x": 0,
        "y": 0,
        "z": "{shop.altura_rodape}"
      },
      "bordas": {
        "frente": true,
        "tras": true,
        "topo": false,
        "base": false
      },
      "notas": "Bordas frontal e traseira visiveis (balcao independente)"
    },
    {
      "nome": "Lateral Direita",
      "role": "lateral_dir",
      "largura": "{altura} - {shop.altura_rodape}",
      "altura": "{profundidade}",
      "espessura": "{shop.espessura}",
      "posicao": {
        "x": "{largura} - {shop.espessura}",
        "y": 0,
        "z": "{shop.altura_rodape}"
      },
      "bordas": {
        "frente": true,
        "tras": true,
        "topo": false,
        "base": false
      }
    },
    {
      "nome": "Base",
      "role": "base",
      "largura": "{largura} - 2 * {shop.espessura}",
      "altura": "{profundidade}",
      "espessura": "{shop.espessura}",
      "posicao": {
        "x": "{shop.espessura}",
        "y": 0,
        "z": "{shop.altura_rodape}"
      },
      "bordas": {
        "frente": true,
        "tras": false,
        "topo": false,
        "base": false
      }
    },
    {
      "nome": "Tampo",
      "role": "topo",
      "largura": "{largura}",
      "altura": "{profundidade} + 50",
      "espessura": "{shop.espessura}",
      "posicao": {
        "x": 0,
        "y": -25,
        "z": "{altura} - {shop.espessura}"
      },
      "bordas": {
        "frente": true,
        "tras": true,
        "topo": true,
        "base": true
      },
      "notas": "Tampo sobreposto com beirada maior que o corpo"
    },
    {
      "nome": "Painel Frontal",
      "role": "traseira",
      "largura": "{largura} - 2 * {shop.espessura}",
      "altura": "{altura} - {shop.altura_rodape} - 2 * {shop.espessura}",
      "espessura": "{shop.espessura}",
      "posicao": {
        "x": "{shop.espessura}",
        "y": 0,
        "z": "{shop.altura_rodape} + {shop.espessura}"
      },
      "bordas": {
        "frente": true,
        "tras": false,
        "topo": false,
        "base": false
      },
      "notas": "Painel frontal visivel pelo cliente (fecha a frente do balcao)"
    },
    {
      "nome": "Traseira",
      "role": "traseira",
      "largura": "{largura} - 2 * {shop.espessura}",
      "altura": "{altura} - {shop.altura_rodape} - 2 * {shop.espessura}",
      "espessura": 3,
      "condicao": "{com_fundo}",
      "posicao": {
        "x": "{shop.espessura}",
        "y": "{profundidade} - 13",
        "z": "{shop.altura_rodape} + {shop.espessura}"
      },
      "bordas": {
        "frente": false,
        "tras": false,
        "topo": false,
        "base": false
      },
      "notas": "Fundo traseiro (lado do atendente)"
    },
    {
      "nome": "Prateleira 1",
      "role": "prateleira",
      "largura": "{largura} - 2 * {shop.espessura}",
      "altura": "{profundidade} - 40",
      "espessura": "{shop.espessura}",
      "condicao": "{n_prateleiras} >= 1",
      "posicao": {
        "x": "{shop.espessura}",
        "y": 20,
        "z": "{shop.altura_rodape} + ({altura} - {shop.altura_rodape}) / ({n_prateleiras} + 1)"
      },
      "bordas": {
        "frente": true,
        "tras": false,
        "topo": false,
        "base": false
      }
    },
    {
      "nome": "Prateleira 2",
      "role": "prateleira",
      "largura": "{largura} - 2 * {shop.espessura}",
      "altura": "{profundidade} - 40",
      "espessura": "{shop.espessura}",
      "condicao": "{n_prateleiras} >= 2",
      "posicao": {
        "x": "{shop.espessura}",
        "y": 20,
        "z": "{shop.altura_rodape} + 2 * ({altura} - {shop.altura_rodape}) / ({n_prateleiras} + 1)"
      },
      "bordas": {
        "frente": true,
        "tras": false,
        "topo": false,
        "base": false
      }
    },
    {
      "nome": "Prateleira 3",
      "role": "prateleira",
      "largura": "{largura} - 2 * {shop.espessura}",
      "altura": "{profundidade} - 40",
      "espessura": "{shop.espessura}",
      "condicao": "{n_prateleiras} >= 3",
      "posicao": {
        "x": "{shop.espessura}",
        "y": 20,
        "z": "{shop.altura_rodape} + 3 * ({altura} - {shop.altura_rodape}) / ({n_prateleiras} + 1)"
      },
      "bordas": {
        "frente": true,
        "tras": false,
        "topo": false,
        "base": false
      }
    },
    {
      "nome": "Rodape Frontal",
      "role": "rodape",
      "largura": "{largura} - 2 * {shop.espessura}",
      "altura": "{shop.altura_rodape}",
      "espessura": "{shop.espessura}",
      "condicao": "{com_rodape}",
      "posicao": {
        "x": "{shop.espessura}",
        "y": 0,
        "z": 0
      },
      "bordas": {
        "frente": true,
        "tras": false,
        "topo": false,
        "base": false
      }
    }
  ],
  "ferragens_auto": [
    {
      "regra": "minifix",
      "juncao": "lateral_esq × base",
      "condicao": "{tipo_juncao} == 'minifix'"
    },
    {
      "regra": "minifix",
      "juncao": "lateral_dir × base",
      "condicao": "{tipo_juncao} == 'minifix'"
    },
    {
      "regra": "minifix",
      "juncao": "lateral_esq × topo",
      "condicao": "{tipo_juncao} == 'minifix'"
    },
    {
      "regra": "minifix",
      "juncao": "lateral_dir × topo",
      "condicao": "{tipo_juncao} == 'minifix'"
    },
    {
      "regra": "cavilha",
      "juncao": "lateral_esq × base",
      "condicao": "{tipo_juncao} == 'cavilha'"
    },
    {
      "regra": "cavilha",
      "juncao": "lateral_dir × base",
      "condicao": "{tipo_juncao} == 'cavilha'"
    },
    {
      "regra": "rebaixo_fundo",
      "pecas": [
        "lateral_esq",
        "lateral_dir",
        "base"
      ],
      "condicao": "{com_fundo}"
    },
    {
      "regra": "system32",
      "pecas": [
        "lateral_esq",
        "lateral_dir"
      ],
      "condicao": "{n_prateleiras} > 0"
    }
  ],
  "notas": "Balcao de atendimento sem portas (lado do atendente aberto). Painel frontal fecha a vista do cliente. Tampo sobreposto com beirada.",
