{
  "id": "balcao_pia",
  "nome": "Balcao Pia",
  "descricao": "Armario base para pia de cozinha. Sem tampo (tampo e da pedra). 2 portas com recorte no fundo para encanamento.",
  "categoria": "cozinha",
  "tags": ["base", "pia", "2portas", "cozinha"],
  "icone": "armario_base",

  "parametros": {
    "largura":       { "default": 1000, "min": 800, "max": 1200, "step": 50, "unidade": "mm" },
    "altura":        { "default": 850,  "min": 850, "max": 850,  "step": 50, "unidade": "mm" },
    "profundidade":  { "default": 580,  "min": 580, "max": 580,  "step": 10, "unidade": "mm" },
    "espessura":     { "default": 18,   "min": 15,  "max": 25,   "step": 0.5, "unidade": "mm" },
    "tipo_juncao":   { "default": "minifix", "opcoes": ["minifix", "cavilha", "confirmat"] },
    "com_fundo":     { "default": true },
    "com_rodape":    { "default": true, "altura_rodape": 100 },
    "puxador":       { "default": "modelo_160mm" }
  },

  "pecas": [
    {
      "nome": "Lateral Esquerda",
      "role": "lateral_esq",
      "largura": "{altura} - {altura_rodape}",
      "altura": "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": 0, "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false },
      "notas": "Fita na borda frontal"
    },
    {
      "nome": "Lateral Direita",
      "role": "lateral_dir",
      "largura": "{altura} - {altura_rodape}",
      "altura": "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{largura} - {espessura}", "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Base",
      "role": "base",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Travessa Superior Frontal",
      "role": "travessa",
      "largura": "{largura} - 2 * {espessura}",
      "altura": 80,
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura} - 80" },
      "bordas": { "frontal": false, "traseira": false, "dir": false, "esq": false },
      "notas": "Travessa de rigidez superior frontal"
    },
    {
      "nome": "Travessa Superior Traseira",
      "role": "travessa",
      "largura": "{largura} - 2 * {espessura}",
      "altura": 80,
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": "{profundidade} - {espessura}", "z": "{altura} - 80" },
      "bordas": { "frontal": false, "traseira": false, "dir": false, "esq": false },
      "notas": "Travessa de rigidez superior traseira"
    },
    {
      "nome": "Traseira",
      "role": "traseira",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{altura} - {altura_rodape} - {espessura}",
      "espessura": 3,
      "condicao": "{com_fundo}",
      "posicao": { "x": "{espessura}", "y": "{profundidade} - 13", "z": "{altura_rodape} + {espessura}" },
      "bordas": { "frontal": false, "traseira": false, "dir": false, "esq": false },
      "notas": "Fundo com recorte central para encanamento da pia"
    },
    {
      "nome": "Porta Esquerda",
      "role": "porta",
      "largura": "{altura} - {altura_rodape} - 2",
      "altura": "({largura} - 2 * {espessura}) / 2 - 2",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura_rodape} + 1" },
      "bordas": { "frontal": true, "traseira": true, "dir": true, "esq": true },
      "notas": "Porta esquerda com bordas em todos os lados"
    },
    {
      "nome": "Porta Direita",
      "role": "porta",
      "largura": "{altura} - {altura_rodape} - 2",
      "altura": "({largura} - 2 * {espessura}) / 2 - 2",
      "espessura": "{espessura}",
      "posicao": { "x": "{largura} / 2 + 1", "y": 0, "z": "{altura_rodape} + 1" },
      "bordas": { "frontal": true, "traseira": true, "dir": true, "esq": true }
    },
    {
      "nome": "Rodape",
      "role": "rodape",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{altura_rodape}",
      "espessura": "{espessura}",
      "condicao": "{com_rodape}",
      "posicao": { "x": "{espessura}", "y": 50, "z": 0 },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    }
  ],

  "ferragens_auto": [
    { "regra": "minifix", "juncao": "lateral_esq × base", "condicao": "{tipo_juncao} == 'minifix'" },
    { "regra": "minifix", "juncao": "lateral_dir × base", "condicao": "{tipo_juncao} == 'minifix'" },
    { "regra": "cavilha", "juncao": "lateral_esq × base", "condicao": "{tipo_juncao} == 'cavilha'" },
    { "regra": "cavilha", "juncao": "lateral_dir × base", "condicao": "{tipo_juncao} == 'cavilha'" },
    { "regra": "confirmat", "juncao": "lateral_esq × base", "condicao": "{tipo_juncao} == 'confirmat'" },
    { "regra": "confirmat", "juncao": "lateral_dir × base", "condicao": "{tipo_juncao} == 'confirmat'" },
    { "regra": "dobradica", "peca": "lateral_esq", "condicao": "true" },
    { "regra": "dobradica", "peca": "lateral_dir", "condicao": "true" },
    { "regra": "rebaixo_fundo", "pecas": ["lateral_esq", "lateral_dir", "base"], "condicao": "{com_fundo}" },
    { "regra": "puxador", "peca": "porta", "condicao": "true" }
  ]
}
