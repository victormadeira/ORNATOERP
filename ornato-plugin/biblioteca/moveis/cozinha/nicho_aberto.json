{
  "id": "nicho_aberto",
  "nome": "Nicho Aberto",
  "categoria": "cozinha",
  "descricao": "Nicho aberto para decoração, temperos ou prateleiras expostas",
  "icone": "nicho",
  "thumbnail": "nicho_aberto.png",

  "parametros": {
    "largura":      { "label": "Largura (mm)",     "default": 600,  "min": 200,  "max": 1200, "step": 50 },
    "altura":       { "label": "Altura (mm)",      "default": 400,  "min": 200,  "max": 800,  "step": 10 },
    "profundidade": { "label": "Profundidade (mm)", "default": 300,  "min": 150,  "max": 450,  "step": 10 },
    "espessura":    { "label": "Espessura MDF",    "default": 18,   "min": 15,   "max": 25,   "step": 1  },
    "material":     { "label": "Material",         "default": "MDF18_BrancoTX" },
    "com_fundo":    { "label": "Com fundo",        "default": true  },
    "n_prateleiras":{ "label": "Prateleiras internas", "default": 1, "min": 0, "max": 4, "step": 1 }
  },

  "pecas": [
    {
      "nome": "Lateral Esq",
      "role": "lateral",
      "largura":   "{altura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": 0, "y": 0, "z": 0 },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": false }
    },
    {
      "nome": "Lateral Dir",
      "role": "lateral",
      "largura":   "{altura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{largura} - {espessura}", "y": 0, "z": 0 },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": false }
    },
    {
      "nome": "Base",
      "role": "base",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": 0 },
      "bordas": { "frente": true, "topo": false, "base": true, "tras": false }
    },
    {
      "nome": "Topo",
      "role": "top",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura} - {espessura}" },
      "bordas": { "frente": true, "topo": true, "base": false, "tras": false }
    },
    {
      "nome": "Traseira",
      "role": "back_panel",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{altura} - 2 * {espessura}",
      "espessura": 3,
      "posicao": { "x": "{espessura}", "y": "{profundidade} - 13", "z": "{espessura}" },
      "bordas": { "frente": false, "topo": false, "base": false, "tras": false },
      "condicao": "{com_fundo} == true"
    },
    {
      "nome": "Prateleira 1",
      "role": "shelf",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade} - 20",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura}",
        "y": 0,
        "z": "round(({altura} - {espessura}) / ({n_prateleiras} + 1))"
      },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{n_prateleiras} >= 1"
    },
    {
      "nome": "Prateleira 2",
      "role": "shelf",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade} - 20",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura}",
        "y": 0,
        "z": "round(({altura} - {espessura}) * 2 / ({n_prateleiras} + 1))"
      },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{n_prateleiras} >= 2"
    },
    {
      "nome": "Prateleira 3",
      "role": "shelf",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade} - 20",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura}",
        "y": 0,
        "z": "round(({altura} - {espessura}) * 3 / ({n_prateleiras} + 1))"
      },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{n_prateleiras} >= 3"
    }
  ],

  "ferragens_auto": [
    { "tipo": "minifix",  "aplica_em": ["lateral", "base", "top"] },
    { "tipo": "cavilha",  "aplica_em": ["lateral", "shelf"] },
    { "tipo": "system32", "aplica_em": "lateral", "condicao": "{n_prateleiras} > 0" }
  ],

  "agregados_sugeridos": ["led"]
}
