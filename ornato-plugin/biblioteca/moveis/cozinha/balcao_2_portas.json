{
  "id": "balcao_2_portas",
  "codigo": "ORN_BAL_001",
  "nome": "Balcao 2 Portas",
  "descricao": "Modulo base parametrico de cozinha com duas portas de abrir, prateleiras opcionais, fundo, tampo e rodape configuraveis.",
  "categoria": "cozinha",
  "tags": [
    "base",
    "balcao",
    "2portas",
    "cozinha",
    "parametrico"
  ],
  "icone": "armario_base",
  "thumbnail": "balcao_2_portas.png",
  "tipo_ruby": "balcao_2_portas",
  "versao_schema": 1,
  "parametros": {
    "largura": {
      "label": "Largura",
      "type": "number",
      "default": 800,
      "min": 400,
      "max": 1200,
      "step": 10,
      "unit": "mm",
      "unidade": "mm"
    },
    "altura": {
      "label": "Altura",
      "type": "number",
      "default": 720,
      "min": 650,
      "max": 900,
      "step": 10,
      "unit": "mm",
      "unidade": "mm"
    },
    "profundidade": {
      "label": "Profundidade",
      "type": "number",
      "default": 560,
      "min": 450,
      "max": 650,
      "step": 10,
      "unit": "mm",
      "unidade": "mm"
    },
    "espessura": {
      "label": "Espessura MDF",
      "type": "number",
      "default": 18,
      "min": 15,
      "max": 25,
      "step": 1,
      "unit": "mm",
      "unidade": "mm"
    },
    "altura_rodape": {
      "label": "Rodape",
      "type": "number",
      "default": 100,
      "min": 0,
      "max": 180,
      "step": 10,
      "unit": "mm",
      "unidade": "mm"
    },
    "material_carcaca": {
      "label": "Material carcaca",
      "type": "select",
      "default": "MDF18_BrancoTX",
      "options": [
        "MDF18_BrancoTX",
        "MDF18_Branco",
        "MDF18_Cinza",
        "MDF18_Natural",
        "MDF25_BrancoTX"
      ],
      "opcoes": [
        "MDF18_BrancoTX",
        "MDF18_Branco",
        "MDF18_Cinza",
        "MDF18_Natural",
        "MDF25_BrancoTX"
      ]
    },
    "material_frente": {
      "label": "Material portas",
      "type": "select",
      "default": "MDF18_BrancoTX",
      "options": [
        "MDF18_BrancoTX",
        "MDF18_Branco",
        "MDF18_Cinza",
        "MDF18_Natural",
        "MDF18_Lacado",
        "MDF25_BrancoTX"
      ],
      "opcoes": [
        "MDF18_BrancoTX",
        "MDF18_Branco",
        "MDF18_Cinza",
        "MDF18_Natural",
        "MDF18_Lacado",
        "MDF25_BrancoTX"
      ]
    },
    "material_fundo": {
      "label": "Material fundo",
      "type": "select",
      "default": "MDF6_Branco",
      "options": [
        "MDF6_Branco",
        "MDF12_Branco",
        "MDF18_Branco"
      ],
      "opcoes": [
        "MDF6_Branco",
        "MDF12_Branco",
        "MDF18_Branco"
      ]
    },
    "com_tampo": {
      "label": "Com tampo",
      "type": "boolean",
      "default": true
    },
    "com_fundo": {
      "label": "Com fundo",
      "type": "boolean",
      "default": true
    },
    "n_prateleiras": {
      "label": "Prateleiras",
      "type": "number",
      "default": 1,
      "min": 0,
      "max": 3,
      "step": 1
    },
    "tipo_juncao": {
      "label": "Juncao",
      "type": "select",
      "default": "minifix",
      "options": [
        "minifix",
        "cavilha",
        "confirmat"
      ],
      "opcoes": [
        "minifix",
        "cavilha",
        "confirmat"
      ]
    },
    "folga_porta_lateral": {
      "label": "Folga lateral porta",
      "type": "number",
      "default": 2,
      "min": 1,
      "max": 5,
      "step": 0.5,
      "unit": "mm",
      "unidade": "mm"
    },
    "folga_porta_vertical": {
      "label": "Folga vertical porta",
      "type": "number",
      "default": 2,
      "min": 1,
      "max": 5,
      "step": 0.5,
      "unit": "mm",
      "unidade": "mm"
    },
    "folga_entre_portas": {
      "label": "Folga entre portas",
      "type": "number",
      "default": 3,
      "min": 1,
      "max": 6,
      "step": 0.5,
      "unit": "mm",
      "unidade": "mm"
    },
    "recuo_fundo": {
      "label": "Recuo fundo",
      "type": "number",
      "default": 13,
      "min": 8,
      "max": 25,
      "step": 1,
      "unit": "mm",
      "unidade": "mm"
    },
    "puxador_espacamento": {
      "label": "Puxador",
      "type": "number",
      "default": 128,
      "min": 96,
      "max": 320,
      "step": 32,
      "unit": "mm",
      "unidade": "mm"
    },
    "sys32_ativo": {
      "label": "System 32",
      "type": "boolean",
      "default": true
    }
  },
  "pecas": [
    {
      "nome": "Lateral Esquerda",
      "role": "lateral",
      "orientacao": "lateral",
      "largura": "{altura} - {shop.altura_rodape}",
      "altura": "{profundidade}",
      "espessura": "{shop.espessura}",
      "posicao": {
        "x": 0,
        "y": 0,
        "z": "{altura}"
      },
      "bordas": {
        "frente": true,
        "topo": true,
        "base": false,
        "tras": false
      },
      "obs": "Painel lateral esquerdo; profundidade no eixo Y e altura no eixo Z."
    },
    {
      "nome": "Lateral Direita",
      "role": "lateral",
      "orientacao": "lateral",
      "largura": "{altura} - {shop.altura_rodape}",
      "altura": "{profundidade}",
      "espessura": "{shop.espessura}",
      "posicao": {
        "x": "{largura} - {shop.espessura}",
        "y": 0,
        "z": "{altura}"
      },
      "bordas": {
        "frente": true,
        "topo": true,
        "base": false,
        "tras": false
      },
      "obs": "Painel lateral direito; mesma role canonica para o plugin normalizar ferragens."
    },
    {
      "nome": "Base",
      "role": "base",
      "orientacao": "horizontal",
      "largura": "{largura} - 2 * {shop.espessura}",
      "altura": "{profundidade}",
      "espessura": "{shop.espessura}",
      "posicao": {
        "x": "{shop.espessura}",
        "y": 0,
        "z": "{shop.altura_rodape} + {shop.espessura}"
      },
      "bordas": {
        "frente": true,
        "topo": false,
        "base": false,
        "tras": false
      }
    },
    {
      "nome": "Tampo",
      "role": "top",
      "orientacao": "horizontal",
      "largura": "{largura} - 2 * {shop.espessura}",
      "altura": "{profundidade}",
      "espessura": "{shop.espessura}",
      "condicao": "{com_tampo} == true",
      "posicao": {
        "x": "{shop.espessura}",
        "y": 0,
        "z": "{altura}"
      },
      "bordas": {
        "frente": true,
        "topo": false,
        "base": false,
        "tras": false
      }
    },
    {
      "nome": "Traseira",
      "role": "back_panel",
      "largura": "{largura} - 2 * {shop.espessura}",
      "altura": "{altura} - {shop.altura_rodape} - 2 * {shop.espessura}",
      "espessura": 6,
      "condicao": "{com_fundo} == true",
      "posicao": {
        "x": "{shop.espessura}",
        "y": "{profundidade} - {shop.recuo_fundo}",
        "z": "{altura} - {shop.espessura}"
      },
      "bordas": {
        "frente": false,
        "topo": false,
        "base": false,
        "tras": false
      },
      "obs": "Fundo recuado para rasgo; material resolvido por material_fundo."
    },
    {
      "nome": "Prateleira 1",
      "role": "shelf",
      "orientacao": "horizontal",
      "largura": "{largura} - 2 * {shop.espessura} - 2",
      "altura": "{profundidade} - 20",
      "espessura": "{shop.espessura}",
      "condicao": "{n_prateleiras} >= 1",
      "posicao": {
        "x": "{shop.espessura} + 1",
        "y": 0,
        "z": "{shop.altura_rodape} + ({altura} - {shop.altura_rodape}) / 2 + {shop.espessura}"
      },
      "bordas": {
        "frente": true,
        "topo": false,
        "base": false,
        "tras": false
      }
    },
    {
      "nome": "Prateleira 2",
      "role": "shelf",
      "orientacao": "horizontal",
      "largura": "{largura} - 2 * {shop.espessura} - 2",
      "altura": "{profundidade} - 20",
      "espessura": "{shop.espessura}",
      "condicao": "{n_prateleiras} >= 2",
      "posicao": {
        "x": "{shop.espessura} + 1",
        "y": 0,
        "z": "{shop.altura_rodape} + ({altura} - {shop.altura_rodape}) / 3 + {shop.espessura}"
      },
      "bordas": {
        "frente": true,
        "topo": false,
        "base": false,
        "tras": false
      }
    },
    {
      "nome": "Prateleira 3",
      "role": "shelf",
      "orientacao": "horizontal",
      "largura": "{largura} - 2 * {shop.espessura} - 2",
      "altura": "{profundidade} - 20",
      "espessura": "{shop.espessura}",
      "condicao": "{n_prateleiras} >= 3",
      "posicao": {
        "x": "{shop.espessura} + 1",
        "y": 0,
        "z": "{shop.altura_rodape} + 2 * ({altura} - {shop.altura_rodape}) / 3 + {shop.espessura}"
      },
      "bordas": {
        "frente": true,
        "topo": false,
        "base": false,
        "tras": false
      }
    },
    {
      "nome": "Porta Esquerda",
      "role": "door",
      "largura": "({largura} - 2 * {shop.folga_porta_lateral} - {shop.folga_entre_portas}) / 2",
      "altura": "{altura} - {shop.altura_rodape} - 2 * {shop.folga_porta_vertical}",
      "espessura": "{shop.espessura}",
      "posicao": {
        "x": "{shop.folga_porta_lateral}",
        "y": "0 - {shop.espessura} - 2",
        "z": "{altura} - {shop.folga_porta_vertical}"
      },
      "bordas": {
        "frente": true,
        "topo": true,
        "base": true,
        "tras": true
      },
      "obs": "Frente externa esquerda, com fitas em todos os lados."
    },
    {
      "nome": "Porta Direita",
      "role": "door",
      "largura": "({largura} - 2 * {shop.folga_porta_lateral} - {shop.folga_entre_portas}) / 2",
      "altura": "{altura} - {shop.altura_rodape} - 2 * {shop.folga_porta_vertical}",
      "espessura": "{shop.espessura}",
      "posicao": {
        "x": "({largura} + {shop.folga_entre_portas}) / 2",
        "y": "0 - {shop.espessura} - 2",
        "z": "{altura} - {shop.folga_porta_vertical}"
      },
      "bordas": {
        "frente": true,
        "topo": true,
        "base": true,
        "tras": true
      },
      "obs": "Frente externa direita, parametrica com folga central."
    },
    {
      "nome": "Rodape",
      "role": "kick",
      "largura": "{largura} - 2 * {shop.espessura}",
      "altura": "{shop.altura_rodape}",
      "espessura": "{shop.espessura}",
      "condicao": "{shop.altura_rodape} > 0",
      "posicao": {
        "x": "{shop.espessura}",
        "y": 50,
        "z": "{shop.altura_rodape}"
      },
      "bordas": {
        "frente": true,
        "topo": false,
        "base": false,
        "tras": false
      }
    }
  ],
  "ferragens_auto": [
    {
      "regra": "minifix",
      "juncao": "lateral × base",
      "condicao": "{tipo_juncao} == 'minifix'"
    },
    {
      "regra": "minifix",
      "juncao": "lateral × top",
      "condicao": "{tipo_juncao} == 'minifix' && {com_tampo} == true"
    },
    {
      "regra": "cavilha",
      "juncao": "lateral × base",
      "condicao": "{tipo_juncao} == 'cavilha'"
    },
    {
      "regra": "cavilha",
      "juncao": "lateral × top",
      "condicao": "{tipo_juncao} == 'cavilha' && {com_tampo} == true"
    },
    {
      "regra": "confirmat",
      "juncao": "lateral × base",
      "condicao": "{tipo_juncao} == 'confirmat'"
    },
    {
      "regra": "confirmat",
      "juncao": "lateral × top",
      "condicao": "{tipo_juncao} == 'confirmat' && {com_tampo} == true"
    },
    {
      "regra": "dobradica",
      "peca": "lateral"
    },
    {
      "regra": "puxador",
      "peca": "door",
      "espacamento": "{puxador_espacamento}"
    },
    {
      "regra": "rebaixo_fundo",
      "pecas": [
        "lateral",
        "base",
        "top"
      ],
      "condicao": "{com_fundo} == true"
    },
    {
      "regra": "system32",
      "pecas": [
        "lateral"
      ],
      "condicao": "{sys32_ativo} == true && {n_prateleiras} > 0"
    }
  ],
  "agregados_sugeridos": [
    "led",
    "passa_fio",
    "puxador"
  ]
}
