{
  "id": "canto_l",
  "nome": "Modulo Canto L",
  "descricao": "Modulo de canto em L para cozinha. Prateleira giratoria interna (acessorio).",
  "categoria": "cozinha",
  "tags": ["base", "canto", "L", "giratoria", "cozinha"],
  "icone": "armario_canto",

  "parametros": {
    "largura":        { "default": 1000, "min": 900, "max": 1100, "step": 50, "unidade": "mm" },
    "largura_lado_b": { "default": 1000, "min": 900, "max": 1100, "step": 50, "unidade": "mm" },
    "altura":         { "default": 850,  "min": 850, "max": 850,  "step": 50, "unidade": "mm" },
    "profundidade":   { "default": 580,  "min": 580, "max": 580,  "step": 10, "unidade": "mm" },
    "espessura":      { "default": 18,   "min": 15,  "max": 25,   "step": 0.5, "unidade": "mm" },
    "tipo_juncao":    { "default": "minifix", "opcoes": ["minifix", "cavilha", "confirmat"] },
    "com_fundo":      { "default": true },
    "com_rodape":     { "default": true, "altura_rodape": 100 },
    "puxador":        { "default": "modelo_160mm" }
  },

  "pecas": [
    {
      "nome": "Lateral Esquerda (lado A)",
      "role": "lateral_esq",
      "largura": "{altura} - {altura_rodape}",
      "altura": "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": 0, "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Lateral Direita (lado B)",
      "role": "lateral_dir",
      "largura": "{altura} - {altura_rodape}",
      "altura": "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{largura_lado_b} - {espessura}", "y": "{largura} - {profundidade}", "z": "{altura_rodape}" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false },
      "notas": "Lateral no sentido perpendicular (lado B do L)"
    },
    {
      "nome": "Base",
      "role": "base",
      "largura": "{largura_lado_b} - {espessura}",
      "altura": "{largura} - {espessura}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": "{espessura}", "z": "{altura_rodape}" },
      "bordas": { "frontal": false, "traseira": false, "dir": false, "esq": false },
      "notas": "Base em formato L cobrindo area total"
    },
    {
      "nome": "Travessa Frontal A",
      "role": "travessa",
      "largura": "{largura_lado_b} - {profundidade}",
      "altura": 80,
      "espessura": "{espessura}",
      "posicao": { "x": "{profundidade}", "y": 0, "z": "{altura} - 80" },
      "bordas": { "frontal": false, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Travessa Frontal B",
      "role": "travessa",
      "largura": 80,
      "altura": "{largura} - {profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": 0, "y": "{profundidade}", "z": "{altura} - 80" },
      "bordas": { "frontal": false, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Traseira Lado A",
      "role": "traseira",
      "largura": "{largura_lado_b} - {espessura}",
      "altura": "{altura} - {altura_rodape} - {espessura}",
      "espessura": 3,
      "condicao": "{com_fundo}",
      "posicao": { "x": "{espessura}", "y": "{largura} - 13", "z": "{altura_rodape} + {espessura}" },
      "bordas": { "frontal": false, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Traseira Lado B",
      "role": "traseira",
      "largura": "{altura} - {altura_rodape} - {espessura}",
      "altura": "{largura} - {profundidade} - {espessura}",
      "espessura": 3,
      "condicao": "{com_fundo}",
      "posicao": { "x": "{largura_lado_b} - 13", "y": "{profundidade} + {espessura}", "z": "{altura_rodape} + {espessura}" },
      "bordas": { "frontal": false, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Porta Lado A",
      "role": "porta",
      "largura": "{altura} - {altura_rodape} - {espessura} - 2",
      "altura": "{largura_lado_b} - {profundidade} - 4",
      "espessura": "{espessura}",
      "posicao": { "x": "{profundidade} + 2", "y": 0, "z": "{altura_rodape} + 1" },
      "bordas": { "frontal": true, "traseira": true, "dir": true, "esq": true }
    },
    {
      "nome": "Porta Lado B",
      "role": "porta",
      "largura": "{largura} - {profundidade} - 4",
      "altura": "{altura} - {altura_rodape} - {espessura} - 2",
      "espessura": "{espessura}",
      "posicao": { "x": 0, "y": "{profundidade} + 2", "z": "{altura_rodape} + 1" },
      "bordas": { "frontal": true, "traseira": true, "dir": true, "esq": true }
    },
    {
      "nome": "Rodape Lado A",
      "role": "rodape",
      "largura": "{largura_lado_b} - {profundidade}",
      "altura": "{altura_rodape}",
      "espessura": "{espessura}",
      "condicao": "{com_rodape}",
      "posicao": { "x": "{profundidade}", "y": 50, "z": 0 },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Rodape Lado B",
      "role": "rodape",
      "largura": "{altura_rodape}",
      "altura": "{largura} - {profundidade}",
      "espessura": "{espessura}",
      "condicao": "{com_rodape}",
      "posicao": { "x": 50, "y": "{profundidade}", "z": 0 },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    }
  ],

  "ferragens_auto": [
    { "regra": "minifix", "juncao": "lateral_esq × base", "condicao": "{tipo_juncao} == 'minifix'" },
    { "regra": "minifix", "juncao": "lateral_dir × base", "condicao": "{tipo_juncao} == 'minifix'" },
    { "regra": "cavilha", "juncao": "lateral_esq × base", "condicao": "{tipo_juncao} == 'cavilha'" },
    { "regra": "cavilha", "juncao": "lateral_dir × base", "condicao": "{tipo_juncao} == 'cavilha'" },
    { "regra": "dobradica", "peca": "lateral_esq", "condicao": "true" },
    { "regra": "dobradica", "peca": "lateral_dir", "condicao": "true" },
    { "regra": "rebaixo_fundo", "pecas": ["lateral_esq", "lateral_dir", "base"], "condicao": "{com_fundo}" },
    { "regra": "puxador", "peca": "porta", "condicao": "true" }
  ],

  "notas": "Modulo em L. Prateleira giratoria e acessorio comprado pronto (nao e peca em MDF). As 2 portas abrem em direcoes perpendiculares."
}
