{
  "id": "torre_forno",
  "nome": "Torre Forno",
  "descricao": "Torre para forno embutido. Abertura central para forno. Gaveta embaixo. Porta acima.",
  "categoria": "cozinha",
  "tags": ["torre", "forno", "embutido", "cozinha"],
  "icone": "torre",

  "parametros": {
    "largura":          { "default": 600,  "min": 600,  "max": 600,  "step": 50, "unidade": "mm" },
    "altura":           { "default": 2100, "min": 2100, "max": 2100, "step": 50, "unidade": "mm" },
    "profundidade":     { "default": 580,  "min": 580,  "max": 580,  "step": 10, "unidade": "mm" },
    "espessura":        { "default": 18,   "min": 15,   "max": 25,   "step": 0.5, "unidade": "mm" },
    "altura_abertura_forno": { "default": 600, "min": 550, "max": 700, "step": 10, "unidade": "mm" },
    "posicao_forno_z":  { "default": 850, "min": 700, "max": 1000, "step": 50, "unidade": "mm" },
    "altura_gaveta":    { "default": 200, "min": 150, "max": 250, "step": 10, "unidade": "mm" },
    "tipo_juncao":      { "default": "minifix", "opcoes": ["minifix", "cavilha", "confirmat"] },
    "com_fundo":        { "default": true },
    "com_rodape":       { "default": true, "altura_rodape": 100 },
    "puxador":          { "default": "modelo_160mm" }
  },

  "pecas": [
    {
      "nome": "Lateral Esquerda",
      "role": "lateral_esq",
      "largura": "{altura} - {altura_rodape}",
      "altura": "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": 0, "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Lateral Direita",
      "role": "lateral_dir",
      "largura": "{altura} - {altura_rodape}",
      "altura": "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{largura} - {espessura}", "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Base",
      "role": "base",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Topo",
      "role": "topo",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura} - {espessura}" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Prateleira Inferior Forno",
      "role": "prateleira",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{posicao_forno_z}" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false },
      "notas": "Base da abertura do forno"
    },
    {
      "nome": "Prateleira Superior Forno",
      "role": "prateleira",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{posicao_forno_z} + {altura_abertura_forno} + {espessura}" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false },
      "notas": "Topo da abertura do forno"
    },
    {
      "nome": "Divisoria Gaveta",
      "role": "divisoria",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura_rodape} + {espessura} + {altura_gaveta}" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false },
      "notas": "Separa gaveta inferior do vao do forno"
    },
    {
      "nome": "Traseira",
      "role": "traseira",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{altura} - {altura_rodape} - 2 * {espessura}",
      "espessura": 3,
      "condicao": "{com_fundo}",
      "posicao": { "x": "{espessura}", "y": "{profundidade} - 13", "z": "{altura_rodape} + {espessura}" },
      "bordas": { "frontal": false, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Frente Gaveta",
      "role": "frente_gaveta",
      "largura": "{altura_gaveta} - 2",
      "altura": "{largura} - 2 * {espessura} - 4",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura} + 2", "y": 0, "z": "{altura_rodape} + {espessura} + 1" },
      "bordas": { "frontal": true, "traseira": true, "dir": true, "esq": true }
    },
    {
      "nome": "Lateral Gaveta Esq",
      "role": "lateral_gaveta",
      "largura": "{altura_gaveta} - 40",
      "altura": "{profundidade} - 80",
      "espessura": 15,
      "posicao": { "x": "{espessura} + 3", "y": 18, "z": "{altura_rodape} + {espessura} + 20" },
      "bordas": { "frontal": false, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Lateral Gaveta Dir",
      "role": "lateral_gaveta",
      "largura": "{altura_gaveta} - 40",
      "altura": "{profundidade} - 80",
      "espessura": 15,
      "posicao": { "x": "{largura} - {espessura} - 18", "y": 18, "z": "{altura_rodape} + {espessura} + 20" },
      "bordas": { "frontal": false, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Fundo Gaveta",
      "role": "fundo_gaveta",
      "largura": "{largura} - 2 * {espessura} - 42",
      "altura": "{profundidade} - 80",
      "espessura": 3,
      "posicao": { "x": "{espessura} + 21", "y": 18, "z": "{altura_rodape} + {espessura} + 20" },
      "bordas": { "frontal": false, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Traseira Gaveta",
      "role": "traseira_gaveta",
      "largura": "{altura_gaveta} - 55",
      "altura": "{largura} - 2 * {espessura} - 42",
      "espessura": 15,
      "posicao": { "x": "{espessura} + 21", "y": "{profundidade} - 77", "z": "{altura_rodape} + {espessura} + 20" },
      "bordas": { "frontal": false, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Porta Superior",
      "role": "porta",
      "largura": "{altura} - {posicao_forno_z} - {altura_abertura_forno} - 2 * {espessura} - 4",
      "altura": "{largura} - 2 * {espessura} - 4",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura} + 2", "y": 0, "z": "{posicao_forno_z} + {altura_abertura_forno} + 2 * {espessura} + 1" },
      "bordas": { "frontal": true, "traseira": true, "dir": true, "esq": true }
    },
    {
      "nome": "Rodape",
      "role": "rodape",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{altura_rodape}",
      "espessura": "{espessura}",
      "condicao": "{com_rodape}",
      "posicao": { "x": "{espessura}", "y": 50, "z": 0 },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    }
  ],

  "ferragens_auto": [
    { "regra": "minifix", "juncao": "lateral_esq × base", "condicao": "{tipo_juncao} == 'minifix'" },
    { "regra": "minifix", "juncao": "lateral_dir × base", "condicao": "{tipo_juncao} == 'minifix'" },
    { "regra": "minifix", "juncao": "lateral_esq × topo", "condicao": "{tipo_juncao} == 'minifix'" },
    { "regra": "minifix", "juncao": "lateral_dir × topo", "condicao": "{tipo_juncao} == 'minifix'" },
    { "regra": "minifix", "juncao": "lateral_esq × prateleira", "condicao": "{tipo_juncao} == 'minifix'" },
    { "regra": "minifix", "juncao": "lateral_dir × prateleira", "condicao": "{tipo_juncao} == 'minifix'" },
    { "regra": "cavilha", "juncao": "lateral_esq × base", "condicao": "{tipo_juncao} == 'cavilha'" },
    { "regra": "cavilha", "juncao": "lateral_dir × base", "condicao": "{tipo_juncao} == 'cavilha'" },
    { "regra": "dobradica", "peca": "lateral_esq", "condicao": "true" },
    { "regra": "corredica", "peca": "lateral_esq", "condicao": "true" },
    { "regra": "corredica", "peca": "lateral_dir", "condicao": "true" },
    { "regra": "rebaixo_fundo", "pecas": ["lateral_esq", "lateral_dir", "base"], "condicao": "{com_fundo}" },
    { "regra": "puxador", "peca": "porta", "condicao": "true" },
    { "regra": "puxador", "peca": "frente_gaveta", "condicao": "true" }
  ]
}
