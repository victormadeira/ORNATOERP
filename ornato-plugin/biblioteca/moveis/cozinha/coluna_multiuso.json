{
  "id": "coluna_multiuso",
  "nome": "Coluna Multiuso",
  "categoria": "cozinha",
  "descricao": "Coluna alta com combinação de portas e prateleiras internas, ideal para despensa",
  "icone": "coluna",
  "thumbnail": "coluna_multiuso.png",

  "parametros": {
    "largura":      { "label": "Largura (mm)",     "default": 600,  "min": 300,  "max": 900,  "step": 50 },
    "altura":       { "label": "Altura (mm)",      "default": 2200, "min": 1800, "max": 2800, "step": 50 },
    "profundidade": { "label": "Profundidade (mm)", "default": 600,  "min": 400,  "max": 700,  "step": 10 },
    "espessura":    { "label": "Espessura MDF",    "default": 18,   "min": 15,   "max": 25,   "step": 1  },
    "altura_rodape":{ "label": "Rodapé (mm)",      "default": 100,  "min": 0,    "max": 150,  "step": 10 },
    "material":     { "label": "Material",         "default": "MDF18_BrancoTX" },
    "com_tampo":    { "label": "Com tampo",        "default": true  },
    "com_fundo":    { "label": "Com fundo",        "default": true  },
    "n_prateleiras":{ "label": "Prateleiras internas", "default": 3, "min": 1, "max": 8, "step": 1 },
    "altura_porta_inf": { "label": "Altura porta inferior (mm)", "default": 700, "min": 400, "max": 1000, "step": 50 }
  },

  "pecas": [
    {
      "nome": "Lateral Esq",
      "role": "lateral",
      "largura":   "{altura} - {altura_rodape}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": 0, "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frente": true, "topo": true, "base": false, "tras": false }
    },
    {
      "nome": "Lateral Dir",
      "role": "lateral",
      "largura":   "{altura} - {altura_rodape}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{largura} - {espessura}", "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frente": true, "topo": true, "base": false, "tras": false }
    },
    {
      "nome": "Base",
      "role": "base",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false }
    },
    {
      "nome": "Tampo",
      "role": "top",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura} - {espessura}" },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{com_tampo} == true"
    },
    {
      "nome": "Traseira",
      "role": "back_panel",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{altura} - {altura_rodape} - 2 * {espessura}",
      "espessura": 3,
      "posicao": { "x": "{espessura}", "y": "{profundidade} - 13", "z": "{altura_rodape} + {espessura}" },
      "bordas": { "frente": false, "topo": false, "base": false, "tras": false },
      "condicao": "{com_fundo} == true"
    },
    {
      "nome": "Divisória Horizontal Inf",
      "role": "shelf",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade} - 20",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura}",
        "y": 0,
        "z": "{altura_rodape} + {altura_porta_inf} + {espessura}"
      },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false }
    },
    {
      "nome": "Porta Inferior",
      "role": "door",
      "largura":   "{altura_porta_inf} - 2",
      "altura":    "{largura} - 2 * {espessura} - 2",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura} + 1",
        "y": 0,
        "z": "{altura_rodape} + {espessura} + 1"
      },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": true }
    },
    {
      "nome": "Porta Superior",
      "role": "door",
      "largura":   "{altura} - {altura_rodape} - {altura_porta_inf} - 3 * {espessura} - 2",
      "altura":    "{largura} - 2 * {espessura} - 2",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura} + 1",
        "y": 0,
        "z": "{altura_rodape} + {altura_porta_inf} + 2 * {espessura} + 1"
      },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": true }
    },
    {
      "nome": "Prateleira 1",
      "role": "shelf",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade} - 20",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura}",
        "y": 0,
        "z": "{altura_rodape} + {altura_porta_inf} + 2 * {espessura} + round(({altura} - {altura_rodape} - {altura_porta_inf} - 2 * {espessura}) / ({n_prateleiras} + 1))"
      },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{n_prateleiras} >= 1"
    },
    {
      "nome": "Prateleira 2",
      "role": "shelf",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade} - 20",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura}",
        "y": 0,
        "z": "{altura_rodape} + {altura_porta_inf} + 2 * {espessura} + round(({altura} - {altura_rodape} - {altura_porta_inf} - 2 * {espessura}) * 2 / ({n_prateleiras} + 1))"
      },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{n_prateleiras} >= 2"
    },
    {
      "nome": "Prateleira 3",
      "role": "shelf",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade} - 20",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura}",
        "y": 0,
        "z": "{altura_rodape} + {altura_porta_inf} + 2 * {espessura} + round(({altura} - {altura_rodape} - {altura_porta_inf} - 2 * {espessura}) * 3 / ({n_prateleiras} + 1))"
      },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{n_prateleiras} >= 3"
    },
    {
      "nome": "Prateleira 4",
      "role": "shelf",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade} - 20",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura}",
        "y": 0,
        "z": "{altura_rodape} + {altura_porta_inf} + 2 * {espessura} + round(({altura} - {altura_rodape} - {altura_porta_inf} - 2 * {espessura}) * 4 / ({n_prateleiras} + 1))"
      },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{n_prateleiras} >= 4"
    },
    {
      "nome": "Prateleira 5",
      "role": "shelf",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade} - 20",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura}",
        "y": 0,
        "z": "{altura_rodape} + {altura_porta_inf} + 2 * {espessura} + round(({altura} - {altura_rodape} - {altura_porta_inf} - 2 * {espessura}) * 5 / ({n_prateleiras} + 1))"
      },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{n_prateleiras} >= 5"
    },
    {
      "nome": "Rodapé",
      "role": "kick",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{altura_rodape}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 50, "z": 0 },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{altura_rodape} > 0"
    }
  ],

  "ferragens_auto": [
    { "tipo": "dobradica",  "aplica_em": "door", "quantidade_por_folha": 4 },
    { "tipo": "puxador",   "aplica_em": "door",  "espacamento": 128 },
    { "tipo": "minifix",   "aplica_em": ["lateral", "base", "top"] },
    { "tipo": "cavilha",   "aplica_em": ["lateral", "shelf"] },
    { "tipo": "system32",  "aplica_em": "lateral", "condicao": "{n_prateleiras} > 0" }
  ],

  "agregados_sugeridos": []
}
