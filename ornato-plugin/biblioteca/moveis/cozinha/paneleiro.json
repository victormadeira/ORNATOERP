{
  "id": "paneleiro",
  "nome": "Paneleiro",
  "descricao": "Armario paneleiro alto com 2 portas altas e prateleiras internas.",
  "categoria": "cozinha",
  "tags": ["paneleiro", "alto", "2portas", "prateleiras", "cozinha"],
  "icone": "torre",

  "parametros": {
    "largura":       { "default": 500,  "min": 400,  "max": 600,  "step": 50, "unidade": "mm" },
    "altura":        { "default": 2100, "min": 2100, "max": 2100, "step": 50, "unidade": "mm" },
    "profundidade":  { "default": 580,  "min": 580,  "max": 580,  "step": 10, "unidade": "mm" },
    "espessura":     { "default": 18,   "min": 15,   "max": 25,   "step": 0.5, "unidade": "mm" },
    "n_prateleiras": { "default": 4,    "min": 2,    "max": 6,    "step": 1 },
    "tipo_juncao":   { "default": "minifix", "opcoes": ["minifix", "cavilha", "confirmat"] },
    "com_fundo":     { "default": true },
    "com_rodape":    { "default": true, "altura_rodape": 100 },
    "puxador":       { "default": "modelo_160mm" }
  },

  "pecas": [
    {
      "nome": "Lateral Esquerda",
      "role": "lateral_esq",
      "largura": "{altura} - {altura_rodape}",
      "altura": "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": 0, "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Lateral Direita",
      "role": "lateral_dir",
      "largura": "{altura} - {altura_rodape}",
      "altura": "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{largura} - {espessura}", "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Base",
      "role": "base",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura_rodape}" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Topo",
      "role": "topo",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura} - {espessura}" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Traseira",
      "role": "traseira",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{altura} - {altura_rodape} - 2 * {espessura}",
      "espessura": 3,
      "condicao": "{com_fundo}",
      "posicao": { "x": "{espessura}", "y": "{profundidade} - 13", "z": "{altura_rodape} + {espessura}" },
      "bordas": { "frontal": false, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Prateleira 1",
      "role": "prateleira",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{profundidade} - 20",
      "espessura": "{espessura}",
      "condicao": "{n_prateleiras} >= 1",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura_rodape} + ({altura} - {altura_rodape}) / ({n_prateleiras} + 1)" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Prateleira 2",
      "role": "prateleira",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{profundidade} - 20",
      "espessura": "{espessura}",
      "condicao": "{n_prateleiras} >= 2",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura_rodape} + 2 * ({altura} - {altura_rodape}) / ({n_prateleiras} + 1)" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Prateleira 3",
      "role": "prateleira",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{profundidade} - 20",
      "espessura": "{espessura}",
      "condicao": "{n_prateleiras} >= 3",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura_rodape} + 3 * ({altura} - {altura_rodape}) / ({n_prateleiras} + 1)" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Prateleira 4",
      "role": "prateleira",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{profundidade} - 20",
      "espessura": "{espessura}",
      "condicao": "{n_prateleiras} >= 4",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura_rodape} + 4 * ({altura} - {altura_rodape}) / ({n_prateleiras} + 1)" },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    },
    {
      "nome": "Porta Esquerda",
      "role": "porta",
      "largura": "{altura} - {altura_rodape} - 2 * {espessura} - 2",
      "altura": "({largura} - 2 * {espessura}) / 2 - 2",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura_rodape} + {espessura} + 1" },
      "bordas": { "frontal": true, "traseira": true, "dir": true, "esq": true }
    },
    {
      "nome": "Porta Direita",
      "role": "porta",
      "largura": "{altura} - {altura_rodape} - 2 * {espessura} - 2",
      "altura": "({largura} - 2 * {espessura}) / 2 - 2",
      "espessura": "{espessura}",
      "posicao": { "x": "{largura} / 2 + 1", "y": 0, "z": "{altura_rodape} + {espessura} + 1" },
      "bordas": { "frontal": true, "traseira": true, "dir": true, "esq": true }
    },
    {
      "nome": "Rodape",
      "role": "rodape",
      "largura": "{largura} - 2 * {espessura}",
      "altura": "{altura_rodape}",
      "espessura": "{espessura}",
      "condicao": "{com_rodape}",
      "posicao": { "x": "{espessura}", "y": 50, "z": 0 },
      "bordas": { "frontal": true, "traseira": false, "dir": false, "esq": false }
    }
  ],

  "ferragens_auto": [
    { "regra": "minifix", "juncao": "lateral_esq × base", "condicao": "{tipo_juncao} == 'minifix'" },
    { "regra": "minifix", "juncao": "lateral_dir × base", "condicao": "{tipo_juncao} == 'minifix'" },
    { "regra": "minifix", "juncao": "lateral_esq × topo", "condicao": "{tipo_juncao} == 'minifix'" },
    { "regra": "minifix", "juncao": "lateral_dir × topo", "condicao": "{tipo_juncao} == 'minifix'" },
    { "regra": "cavilha", "juncao": "lateral_esq × base", "condicao": "{tipo_juncao} == 'cavilha'" },
    { "regra": "cavilha", "juncao": "lateral_dir × base", "condicao": "{tipo_juncao} == 'cavilha'" },
    { "regra": "dobradica", "peca": "lateral_esq", "condicao": "true" },
    { "regra": "dobradica", "peca": "lateral_dir", "condicao": "true" },
    { "regra": "rebaixo_fundo", "pecas": ["lateral_esq", "lateral_dir", "base", "topo"], "condicao": "{com_fundo}" },
    { "regra": "puxador", "peca": "porta", "condicao": "true" },
    { "regra": "system32", "pecas": ["lateral_esq", "lateral_dir"], "condicao": "{n_prateleiras} > 0" }
  ]
}
