      "altura": "{profundidade} - 20",
      "espessura": "{shop.espessura}",
      "condicao": "{n_prateleiras} >= 1",
      "posicao": {
        "x": "{shop.espessura}",
        "y": 0,
        "z": "{altura} / ({n_prateleiras} + 1)"
      },
      "bordas": {
        "frente": true,
        "tras": false,
        "topo": false,
        "base": false
      }
    },
    {
      "nome": "Prateleira 2",
      "role": "prateleira",
      "largura": "{largura} - 2 * {shop.espessura}",
      "altura": "{profundidade} - 20",
      "espessura": "{shop.espessura}",
      "condicao": "{n_prateleiras} >= 2",
      "posicao": {
        "x": "{shop.espessura}",
        "y": 0,
        "z": "2 * {altura} / ({n_prateleiras} + 1)"
      },
      "bordas": {
        "frente": true,
        "tras": false,
        "topo": false,
        "base": false
      }
    },
    {
      "nome": "Prateleira 3",
      "role": "prateleira",
      "largura": "{largura} - 2 * {shop.espessura}",
      "altura": "{profundidade} - 20",
      "espessura": "{shop.espessura}",
      "condicao": "{n_prateleiras} >= 3",
      "posicao": {
        "x": "{shop.espessura}",
        "y": 0,
        "z": "3 * {altura} / ({n_prateleiras} + 1)"
      },
      "bordas": {
        "frente": true,
        "tras": false,
        "topo": false,
        "base": false
      }
    },
    {
      "nome": "Porta com Espelho Unica",
      "role": "porta",
      "largura": "{altura} - 2 * {shop.espessura} - 2",
      "altura": "{largura} - 2 * {shop.espessura} - 4",
      "espessura": "{shop.espessura}",
      "condicao": "{tipo_porta} == '1_abrir_e' || {tipo_porta} == '1_abrir_d'",
      "posicao": {
        "x": "{shop.espessura} + 2",
        "y": 0,
        "z": "{shop.espessura} + 1"
      },
      "bordas": {
        "frente": true,
        "tras": true,
        "topo": true,
        "base": true
      },
