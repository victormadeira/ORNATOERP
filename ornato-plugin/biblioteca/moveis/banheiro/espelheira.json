  "pecas": [
    {
      "nome": "Lateral Esquerda",
      "role": "lateral_esq",
      "largura": "{altura}",
      "altura": "{profundidade}",
      "espessura": "{shop.espessura}",
      "posicao": {
        "x": 0,
        "y": 0,
        "z": 0
      },
      "bordas": {
        "frente": true,
        "tras": false,
        "topo": false,
        "base": false
      }
    },
    {
      "nome": "Lateral Direita",
      "role": "lateral_dir",
      "largura": "{altura}",
      "altura": "{profundidade}",
      "espessura": "{shop.espessura}",
      "posicao": {
        "x": "{largura} - {shop.espessura}",
        "y": 0,
        "z": 0
      },
      "bordas": {
        "frente": true,
        "tras": false,
        "topo": false,
        "base": false
      }
    },
    {
      "nome": "Base",
      "role": "base",
      "largura": "{largura} - 2 * {shop.espessura}",
      "altura": "{profundidade}",
      "espessura": "{shop.espessura}",
      "posicao": {
        "x": "{shop.espessura}",
        "y": 0,
        "z": 0
      },
      "bordas": {
        "frente": true,
        "tras": false,
        "topo": false,
        "base": false
      }
    },
    {
