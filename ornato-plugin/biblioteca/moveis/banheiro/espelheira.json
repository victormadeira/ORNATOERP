      "condicao": "{tipo_juncao} == 'minifix'"
    },
    {
      "regra": "minifix",
      "juncao": "lateral_dir × base",
      "condicao": "{tipo_juncao} == 'minifix'"
    },
    {
      "regra": "minifix",
      "juncao": "lateral_esq × topo",
      "condicao": "{tipo_juncao} == 'minifix'"
