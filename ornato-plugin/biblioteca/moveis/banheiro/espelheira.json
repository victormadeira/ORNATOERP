    {
      "regra": "dobradica",
      "peca": "lateral_dir",
      "condicao": "{tipo_porta} == '1_abrir_d' || {tipo_porta} == '2_abrir'"
    },
    {
      "regra": "rebaixo_fundo",
      "pecas": [
        "lateral_esq",
        "lateral_dir",
        "base",
        "topo"
      ],
      "condicao": "{com_fundo}"
    },
    {
      "regra": "puxador",
      "peca": "porta",
      "condicao": "true"
    },
    {
      "regra": "system32",
      "pecas": [
        "lateral_esq",
        "lateral_dir"
      ],
      "condicao": "{n_prateleiras} > 0"
    }
