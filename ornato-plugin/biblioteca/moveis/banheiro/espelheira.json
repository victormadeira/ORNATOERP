    },
    {
      "nome": "Porta Esquerda com Espelho",
      "role": "porta",
      "largura": "{altura} - 2 * {shop.espessura} - 2",
      "altura": "({largura} - 2 * {shop.espessura}) / 2 - 2",
      "espessura": "{shop.espessura}",
      "condicao": "{tipo_porta} == '2_abrir'",
      "posicao": {
        "x": "{shop.espessura}",
        "y": 0,
        "z": "{shop.espessura} + 1"
      },
      "bordas": {
        "frente": true,
        "tras": true,
        "topo": true,
        "base": true
      },
      "notas": "Porta com espelho colado"
    },
    {
      "nome": "Porta Direita com Espelho",
      "role": "porta",
      "largura": "{altura} - 2 * {shop.espessura} - 2",
      "altura": "({largura} - 2 * {shop.espessura}) / 2 - 2",
      "espessura": "{shop.espessura}",
      "condicao": "{tipo_porta} == '2_abrir'",
      "posicao": {
        "x": "{largura} / 2 + 1",
        "y": 0,
        "z": "{shop.espessura} + 1"
      },
      "bordas": {
        "frente": true,
        "tras": true,
        "topo": true,
        "base": true
      },
      "notas": "Porta com espelho colado"
    }
