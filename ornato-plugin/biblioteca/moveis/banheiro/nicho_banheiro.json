{
  "id": "nicho_banheiro",
  "nome": "Nicho de Banheiro",
  "categoria": "banheiro",
  "descricao": "Nicho embutido ou sobreposto para banheiro com prateleiras internas, ideal para shampoo e itens de higiene",
  "icone": "nicho",
  "thumbnail": "nicho_banheiro.png",

  "parametros": {
    "largura":      { "label": "Largura (mm)",     "default": 400,  "min": 200,  "max": 800,  "step": 50 },
    "altura":       { "label": "Altura (mm)",      "default": 600,  "min": 200,  "max": 1200, "step": 50 },
    "profundidade": { "label": "Profundidade (mm)", "default": 120,  "min": 80,   "max": 250,  "step": 10 },
    "espessura":    { "label": "Espessura MDF",    "default": 18,   "min": 15,   "max": 25,   "step": 1  },
    "material":     { "label": "Material",         "default": "MDF18_BrancoTX" },
    "com_fundo":    { "label": "Com fundo",        "default": true  },
    "n_prateleiras":{ "label": "Prateleiras",      "default": 2,    "min": 0,    "max": 5,    "step": 1  }
  },

  "pecas": [
    {
      "nome": "Lateral Esq",
      "role": "lateral",
      "largura":   "{altura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": 0, "y": 0, "z": 0 },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": false }
    },
    {
      "nome": "Lateral Dir",
      "role": "lateral",
      "largura":   "{altura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{largura} - {espessura}", "y": 0, "z": 0 },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": false }
    },
    {
      "nome": "Base",
      "role": "base",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": 0 },
      "bordas": { "frente": true, "topo": false, "base": true, "tras": false }
    },
    {
      "nome": "Topo",
      "role": "top",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura} - {espessura}" },
      "bordas": { "frente": true, "topo": true, "base": false, "tras": false }
    },
    {
      "nome": "Fundo",
      "role": "back_panel",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{altura} - 2 * {espessura}",
      "espessura": 3,
      "posicao": { "x": "{espessura}", "y": "{profundidade} - 3", "z": "{espessura}" },
      "bordas": { "frente": false, "topo": false, "base": false, "tras": false },
      "condicao": "{com_fundo} == true"
    },
    {
      "nome": "Prateleira 1",
      "role": "shelf",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade} - 3",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura}",
        "y": 0,
        "z": "round({altura} / ({n_prateleiras} + 1))"
      },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{n_prateleiras} >= 1"
    },
    {
      "nome": "Prateleira 2",
      "role": "shelf",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade} - 3",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura}",
        "y": 0,
        "z": "round({altura} * 2 / ({n_prateleiras} + 1))"
      },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{n_prateleiras} >= 2"
    },
    {
      "nome": "Prateleira 3",
      "role": "shelf",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade} - 3",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura}",
        "y": 0,
        "z": "round({altura} * 3 / ({n_prateleiras} + 1))"
      },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{n_prateleiras} >= 3"
    }
  ],

  "ferragens_auto": [
    { "tipo": "minifix", "aplica_em": ["lateral", "base", "top"] },
    { "tipo": "cavilha", "aplica_em": ["lateral", "shelf"] }
  ],

  "agregados_sugeridos": ["led"]
}
