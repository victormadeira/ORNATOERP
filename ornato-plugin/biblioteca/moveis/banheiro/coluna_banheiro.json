{
  "id": "coluna_banheiro",
  "nome": "Coluna de Banheiro",
  "categoria": "banheiro",
  "descricao": "Coluna alta de banheiro com porta superior, gavetas inferiores e espaço para organização",
  "icone": "coluna",
  "thumbnail": "coluna_banheiro.png",

  "parametros": {
    "largura":      { "label": "Largura (mm)",     "default": 350,  "min": 250,  "max": 600,  "step": 50 },
    "altura":       { "label": "Altura (mm)",      "default": 1800, "min": 1400, "max": 2400, "step": 50 },
    "profundidade": { "label": "Profundidade (mm)", "default": 350,  "min": 280,  "max": 500,  "step": 10 },
    "espessura":    { "label": "Espessura MDF",    "default": 18,   "min": 15,   "max": 25,   "step": 1  },
    "material":     { "label": "Material",         "default": "MDF18_BrancoTX" },
    "com_tampo":    { "label": "Com tampo",        "default": true  },
    "com_fundo":    { "label": "Com fundo",        "default": true  },
    "n_gavetas":    { "label": "Gavetas na base",  "default": 2,    "min": 0,    "max": 4,    "step": 1  },
    "altura_gavetas":{ "label": "Altura da seção de gavetas (mm)", "default": 400, "min": 0, "max": 700, "step": 50 },
    "n_prateleiras":{ "label": "Prateleiras internas", "default": 2, "min": 0, "max": 6, "step": 1 }
  },

  "pecas": [
    {
      "nome": "Lateral Esq",
      "role": "lateral",
      "largura":   "{altura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": 0, "y": 0, "z": 0 },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": false }
    },
    {
      "nome": "Lateral Dir",
      "role": "lateral",
      "largura":   "{altura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{largura} - {espessura}", "y": 0, "z": 0 },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": false }
    },
    {
      "nome": "Base",
      "role": "base",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": 0 },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false }
    },
    {
      "nome": "Tampo",
      "role": "top",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade}",
      "espessura": "{espessura}",
      "posicao": { "x": "{espessura}", "y": 0, "z": "{altura} - {espessura}" },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{com_tampo} == true"
    },
    {
      "nome": "Traseira",
      "role": "back_panel",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{altura} - 2 * {espessura}",
      "espessura": 3,
      "posicao": { "x": "{espessura}", "y": "{profundidade} - 13", "z": "{espessura}" },
      "bordas": { "frente": false, "topo": false, "base": false, "tras": false },
      "condicao": "{com_fundo} == true"
    },
    {
      "nome": "Divisória Gavetas",
      "role": "shelf",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade} - 20",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura}",
        "y": 0,
        "z": "{altura_gavetas} + {espessura}"
      },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{n_gavetas} >= 1 && {altura_gavetas} > 0"
    },
    {
      "nome": "Frente Gaveta 1",
      "role": "drawer_front",
      "largura":   "round({altura_gavetas} / {n_gavetas}) - 2",
      "altura":    "{largura} - 2 * {espessura} - 2",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura} + 1",
        "y": 0,
        "z": "{espessura} + 1"
      },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": true },
      "condicao": "{n_gavetas} >= 1"
    },
    {
      "nome": "Frente Gaveta 2",
      "role": "drawer_front",
      "largura":   "round({altura_gavetas} / {n_gavetas}) - 2",
      "altura":    "{largura} - 2 * {espessura} - 2",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura} + 1",
        "y": 0,
        "z": "{espessura} + round({altura_gavetas} / {n_gavetas}) + 1"
      },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": true },
      "condicao": "{n_gavetas} >= 2"
    },
    {
      "nome": "Porta Superior",
      "role": "door",
      "largura":   "{altura} - {altura_gavetas} - 3 * {espessura} - 2",
      "altura":    "{largura} - 2 * {espessura} - 2",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura} + 1",
        "y": 0,
        "z": "{altura_gavetas} + 2 * {espessura} + 1"
      },
      "bordas": { "frente": true, "topo": true, "base": true, "tras": true }
    },
    {
      "nome": "Prateleira 1",
      "role": "shelf",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade} - 20",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura}",
        "y": 0,
        "z": "{altura_gavetas} + 2 * {espessura} + round(({altura} - {altura_gavetas} - 2 * {espessura}) / ({n_prateleiras} + 1))"
      },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{n_prateleiras} >= 1"
    },
    {
      "nome": "Prateleira 2",
      "role": "shelf",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade} - 20",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura}",
        "y": 0,
        "z": "{altura_gavetas} + 2 * {espessura} + round(({altura} - {altura_gavetas} - 2 * {espessura}) * 2 / ({n_prateleiras} + 1))"
      },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{n_prateleiras} >= 2"
    },
    {
      "nome": "Prateleira 3",
      "role": "shelf",
      "largura":   "{largura} - 2 * {espessura}",
      "altura":    "{profundidade} - 20",
      "espessura": "{espessura}",
      "posicao": {
        "x": "{espessura}",
        "y": 0,
        "z": "{altura_gavetas} + 2 * {espessura} + round(({altura} - {altura_gavetas} - 2 * {espessura}) * 3 / ({n_prateleiras} + 1))"
      },
      "bordas": { "frente": true, "topo": false, "base": false, "tras": false },
      "condicao": "{n_prateleiras} >= 3"
    }
  ],

  "ferragens_auto": [
    { "tipo": "dobradica",  "aplica_em": "door", "quantidade_por_folha": 3 },
    { "tipo": "puxador",   "aplica_em": "door",  "espacamento": 128 },
    { "tipo": "corredica", "aplica_em": "drawer_front", "modelo": "{corredica}" },
    { "tipo": "puxador",   "aplica_em": "drawer_front", "espacamento": 96 },
    { "tipo": "minifix",   "aplica_em": ["lateral", "base", "top"] },
    { "tipo": "cavilha",   "aplica_em": ["lateral", "shelf"] }
  ],

  "agregados_sugeridos": ["espelho"]
}
