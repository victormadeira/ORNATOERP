      },
      {
        "nome": "piloto_1",
        "ferramenta": "broca_2.5mm",
        "diametro": 2.5,
        "profundidade": 10,
        "lado": "a",
        "posicao": { "x": "{offset_borda}", "y": "{pos_y} - 24" }
      },
      {
        "nome": "piloto_2",
        "ferramenta": "broca_2.5mm",
        "diametro": 2.5,
        "profundidade": 10,
        "lado": "a",
        "posicao": { "x": "{offset_borda}", "y": "{pos_y} + 24" }
      }
    ],
    "parametros": {
      "offset_borda": { "default": 22.5, "min": 20, "max": 25 },
      "pos_y": { "default": 100, "min": 80, "max": 150 }
