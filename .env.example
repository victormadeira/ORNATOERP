# ═══════════════════════════════════════════════════════════════
# ORNATO ERP — Variáveis de ambiente (template)
# ═══════════════════════════════════════════════════════════════
# Copie para .env e preencha. O .env NÃO vai pro git.
#
# A maioria dos segredos (Evolution API, OpenAI, Anthropic, Google Drive)
# é armazenada na tabela `empresa_config` do banco, via Configurações no app.
# Este arquivo cobre só as variáveis que o PROCESSO precisa ao subir.

# ── Servidor ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── JWT (autenticação) ────────────────────────────────────────
# Se não definido, o servidor gera e persiste em server/.jwt_secret
# Em produção, defina aqui para invalidar tokens quando quiser
JWT_SECRET=

# ── CORS (origens permitidas, separadas por vírgula) ──────────
# Default: localhost + gestaoornato.com
CORS_ORIGINS=http://localhost:5173,https://gestaoornato.com

# ── Seed inicial (só usado na primeira subida) ────────────────
ADMIN_PASSWORD=admin123

# ── URLs públicas (links em PDFs e portal do cliente) ─────────
PUBLIC_URL=https://gestaoornato.com
BASE_URL=https://gestaoornato.com

# ── OpenAI (fallback; prefira configurar em Config → IA no app) ──
OPENAI_API_KEY=

# ── Puppeteer (geração de PDF) ────────────────────────────────
# Opcional. Se vazio, usa o chromium baixado pelo puppeteer
PUPPETEER_EXECUTABLE_PATH=

# ── CNC optimizer (microserviço Python opcional) ──────────────
CNC_OPTIMIZER_URL=http://localhost:8000

# ── IPInfo (geolocalização em assinaturas/portal) ─────────────
# Token grátis em https://ipinfo.io/
IPINFO_TOKEN=
